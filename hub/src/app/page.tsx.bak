'use client';

import React, { useState, useEffect } from 'react';

// --- Types ---

interface ClusterResources {
  cpuTotal: number;
  cpuUsed: number;
  ramTotal: number;
  ramUsed: number;
}

interface FleetSummary {
  fleetName: string;
  namespace: string;
  ready: number;
  allocated: number;
}

interface ClusterData {
  agentId: string;
  clusterName: string;
  resources: ClusterResources;
  fleets: FleetSummary[];
  lastUpdate: number;
}

// --- Dashboard Components ---

const Gauge = ({ label, used, total, unit }: { label: string; used: number; total: number; unit: string }) => {
  const percent = Math.min((used / total) * 100, 100);
  const color = percent > 85 ? 'var(--chariot-red)' : 'var(--chariot-bronze)';

  return (
    <div className="mb-4">
      <div className="flex justify-between text-xs mb-1 uppercase tracking-widest opacity-80">
        <span>{label}</span>
        <span>{used} / {total} {unit}</span>
      </div>
      <div className="h-2 w-full bg-dark bg-opacity-50 border border-grey-dark">
        <div 
          className="h-full transition-all duration-500 ease-in-out" 
          style={{ width: `${percent}%`, backgroundColor: color }}
        />
      </div>
    </div>
  );
};

const ClusterCard = ({ data }: { data: ClusterData }) => {
  const isStale = Date.now() - data.lastUpdate > 45000; // > 45s since last heartbeat

  return (
    <div className="border border-bronze bg-grey-dark p-6 relative overflow-hidden group hover:border-red transition-colors duration-300">
      {/* Background Accent */}
      <div className="absolute top-0 right-0 w-32 h-32 bg-bronze opacity-5 rotate-45 translate-x-16 -translate-y-16 pointer-events-none" />
      
      <div className="flex justify-between items-start mb-6">
        <div>
          <h3 className="text-xl font-bold uppercase tracking-tighter text-bronze group-hover:text-red transition-colors">
            {data.clusterName}
          </h3>
          <p className="text-[10px] uppercase opacity-50 font-mono">{data.agentId}</p>
        </div>
        <div className="flex items-center gap-2">
          <span className={`w-2 h-2 ${isStale ? 'bg-red animate-pulse' : 'bg-bronze'} inline-block`} />
          <span className="text-[10px] uppercase tracking-widest font-bold">
            {isStale ? 'OUT OF SYNC' : 'ACTIVE'}
          </span>
        </div>
      </div>

      <div className="space-y-2">
        <Gauge label="CPU LOAD" used={data.resources.cpuUsed} total={data.resources.cpuTotal} unit="CORES" />
        <Gauge label="MEMORY" used={data.resources.ramUsed} total={data.resources.ramTotal} unit="GiB" />
      </div>

      <div className="mt-6 pt-4 border-t border-grey-light border-opacity-20">
        <h4 className="text-[10px] font-bold uppercase tracking-widest mb-3 opacity-60">Agones Fleets</h4>
        {data.fleets.length === 0 ? (
          <p className="text-xs italic opacity-40">No active fleets discovered.</p>
        ) : (
          <div className="space-y-2">
            {data.fleets.map(f => (
              <div key={f.fleetName} className="flex justify-between items-center bg-black bg-opacity-20 p-2 text-xs">
                <span className="font-mono">{f.fleetName}</span>
                <span className="text-bronze font-bold">{f.allocated} / {f.ready}</span>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  );
};

// --- Main Dashboard ---

export default function Dashboard() {
  const [clusters, setClusters] = useState<Record<string, ClusterData>>({});
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    // Initial fetch of existing registry state (TODO: Implement GET /api/v1/registry)
    setLoading(false);

    // Subscribe to SSE
    const eventSource = new EventSource('/api/v1/events');
    
    eventSource.onmessage = (event) => {
      try {
        const payload = JSON.parse(event.data);
        if (payload.type === 'CLUSTER_UPDATE') {
          setClusters(prev => ({
            ...prev,
            [payload.agentId]: {
              agentId: payload.agentId,
              clusterName: payload.data.metadata?.cluster_name || payload.agentId,
              resources: payload.data.resources,
              fleets: payload.data.fleets || [],
              lastUpdate: payload.timestamp
            }
          }));
        }
      } catch (err) {
        console.error('Failed to parse SSE event:', err);
      }
    };

    return () => eventSource.close();
  }, []);

  return (
    <main className="min-h-screen bg-dark text-white p-8">
      {/* Header Section */}
      <header className="mb-12 border-b-2 border-red pb-6 flex justify-between items-end">
        <div>
          <h1 className="text-6xl font-black tracking-tighter uppercase leading-none">
            Chariot<span className="text-red">.</span>
          </h1>
          <p className="mt-2 text-xs uppercase tracking-[0.3em] font-bold text-bronze opacity-80">
            Multi-Cluster Agones Orchestrator
          </p>
        </div>
        <div className="text-right">
          <div className="text-[10px] uppercase tracking-widest font-bold opacity-40 mb-1">System Status</div>
          <div className="flex gap-4">
              <div className="px-3 py-1 border border-bronze text-bronze text-[10px] font-bold">HUB: OPERATIONAL</div>
              <div className="px-3 py-1 border border-red text-red text-[10px] font-bold">STREAM: ACTIVE</div>
          </div>
        </div>
      </header>

      {/* Stats Overview (Optional) */}
      <section className="grid grid-cols-4 gap-4 mb-12">
        <div className="border border-grey-light p-4 bg-grey-dark bg-opacity-30">
          <div className="text-[10px] uppercase tracking-widest font-bold opacity-50 mb-1">Active Clusters</div>
          <div className="text-3xl font-black">{Object.keys(clusters).length}</div>
        </div>
      </section>

      {/* Clusters Grid */}
      {loading ? (
        <div className="flex items-center justify-center h-64">
          <div className="w-12 h-12 border-4 border-bronze border-t-red animate-spin" />
        </div>
      ) : (
        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {Object.values(clusters).length === 0 ? (
            <div className="col-span-full border-2 border-dashed border-grey-light p-12 text-center">
              <p className="text-xl uppercase tracking-widest font-black opacity-20">Waiting for Agent Discovery...</p>
            </div>
          ) : (
            Object.values(clusters).map(cluster => (
              <ClusterCard key={cluster.agentId} data={cluster} />
            ))
          )}
        </div>
      )}
    </main>
  );
}
